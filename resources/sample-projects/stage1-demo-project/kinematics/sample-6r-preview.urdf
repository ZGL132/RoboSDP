<?xml version="1.0"?>
<robot name="sample_6r_preview">
  <link name="base_link" />
  <link name="link_1" />
  <link name="link_2" />
  <link name="tool_link" />

  <joint name="joint_1" type="revolute">
    <parent link="base_link" />
    <child link="link_1" />
    <origin xyz="0 0 0.40" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14" upper="3.14" effort="120" velocity="2.0" />
  </joint>

  <joint name="joint_2" type="revolute">
    <parent link="link_1" />
    <child link="link_2" />
    <origin xyz="0.35 0 0.25" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-2.6" upper="2.6" effort="120" velocity="2.0" />
  </joint>

  <joint name="joint_3" type="fixed">
    <parent link="link_2" />
    <child link="tool_link" />
    <origin xyz="0.22 0 0.18" rpy="0 0 0" />
  </joint>
</robot>
